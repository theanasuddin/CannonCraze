# Copy this file to keystore.properties (same folder) and fill in the values
# for your upload keystore. keystore.properties is gitignored on purpose:
# signing secrets must never be committed.
#
# Create the keystore once with:
#   keytool -genkeypair -v -keystore cannoncraze-upload.jks -alias upload \
#     -keyalg RSA -keysize 2048 -validity 10000
#
# storeFile is resolved relative to the app/ module folder.
storeFile=../cannoncraze-upload.jks
storePassword=CHANGE_ME
keyAlias=upload
keyPassword=CHANGE_ME
